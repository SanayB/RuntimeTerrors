{
  "manifest_version": 3,
  "name": "Shadow SaaS Security Detector",
  "version": "1.0",
  "description": "Monitors websites in real-time, detects unauthorized SaaS platforms, and collects browser security metadata.",
  "permissions": [
    "tabs",
    "storage",
    "cookies",
    "history",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["utils.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
